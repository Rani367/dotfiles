{
  "include": {
    "prefix": "inc",
    "body": "#include <${1:stdio.h}>",
    "description": "Include header"
  },
  "include local": {
    "prefix": "incl",
    "body": "#include \"${1:header.h}\"",
    "description": "Include local header"
  },
  "main": {
    "prefix": "main",
    "body": [
      "int main(int argc, char *argv[])",
      "{",
      "\t${0}",
      "\treturn 0;",
      "}"
    ],
    "description": "Main function"
  },
  "printf": {
    "prefix": "pf",
    "body": "printf(\"${1:%s}\\n\"${2:, ${3:var}});",
    "description": "Printf"
  },
  "for": {
    "prefix": "for",
    "body": [
      "for (int ${1:i} = 0; $1 < ${2:n}; $1++)",
      "{",
      "\t${0}",
      "}"
    ],
    "description": "For loop"
  },
  "if": {
    "prefix": "if",
    "body": [
      "if (${1:condition})",
      "{",
      "\t${0}",
      "}"
    ],
    "description": "If statement"
  },
  "struct": {
    "prefix": "st",
    "body": [
      "typedef struct ${1:name}",
      "{",
      "\t${0}",
      "} ${1};"
    ],
    "description": "Typedef struct"
  },
  "header guard": {
    "prefix": "guard",
    "body": [
      "#ifndef ${1:HEADER_H}",
      "#define $1",
      "",
      "${0}",
      "",
      "#endif // $1"
    ],
    "description": "Header guard"
  }
}
